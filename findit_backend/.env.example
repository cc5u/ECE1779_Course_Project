# Local development environment.
# For Swarm deployment, use `.env.stack.example` instead of this file.

# Database for local host-side development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/findit?schema=public"

# Optional Docker Compose override for the backend container
DATABASE_URL_DOCKER="postgresql://postgres:postgres@postgres:5432/findit?schema=public"

# Optional Redis Pub/Sub for cross-instance WebSocket fan-out.
# Leave REDIS_URL unset for host-side development if you do not have Redis running locally.
REDIS_URL=
# Docker Compose uses the Redis service hostname.
REDIS_URL_DOCKER=redis://redis:6379

# Server
PORT=3000
NODE_ENV=development
# Comma-separated extra frontend origins, no trailing slash.
# The origin from BASE_URL is always allowed automatically.
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.example.com
BASE_URL=http://localhost:3000

# JWT Secret (change this in production!)
JWT_SECRET="your-super-secret-jwt-key-change-me"
JWT_EXPIRES_IN="7d"

# DigitalOcean Spaces (optional; if unset, uploads fall back to local /uploads storage)
# Example endpoint: https://nyc3.digitaloceanspaces.com
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=
# Optional CDN hostname or custom domain, without a trailing slash.
DO_SPACES_CDN_ENDPOINT=
