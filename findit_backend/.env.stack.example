# Docker Swarm deployment variables for `docker-stack.yml`.
# Copy this file to `.env.stack` on the Swarm manager node and fill in real values.
# `scripts/deploy-stack.sh` exports this file before running `docker stack deploy`.

STACK_NAME=findit
BACKEND_IMAGE=your-dockerhub-user/findit-backend:latest

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=findit
POSTGRES_DATA_DIR=/mnt/volume_tor1_01/postgres-data

# This must use the Swarm service hostname `postgres`, not localhost.
# If your password contains special characters, URL-encode it here.
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/findit?schema=public
REDIS_URL=redis://redis:6379

PUBLISHED_PORT=3000
PORT=3000
NODE_ENV=production
BACKEND_REPLICAS=1

JWT_SECRET=change-me-jwt-secret
JWT_EXPIRES_IN=7d
# Extra allowed origins besides the public BASE_URL origin, which is allowed automatically.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
BASE_URL=http://your-server-ip-or-domain

# Leave the Spaces variables blank to fall back to local /uploads storage.
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=
DO_SPACES_CDN_ENDPOINT=
