# Optional production overrides for the frontend build.
# Leave these unset when the frontend is served behind the same Nginx entrypoint as the backend.
# The app will then default to:
#   API: <current-origin>/api
#   WS:  <current-origin>/ws
#
# Local Vite development also proxies /api, /ws, and /uploads to http://localhost:3000 by default.
# Override that proxy target here only if your backend container is exposed on a different host or port.

# VITE_DEV_PROXY_TARGET=http://localhost:3000

# VITE_API_BASE_URL=http://your-server-ip/api
# VITE_WS_BASE_URL=ws://your-server-ip
