# Database for local host-side development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/findit?schema=public"

# Optional Docker Compose override for the backend container
DATABASE_URL_DOCKER="postgresql://postgres:postgres@postgres:5432/findit?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT Secret (change this in production!)
JWT_SECRET="your-super-secret-jwt-key-change-me"
JWT_EXPIRES_IN="7d"

# DigitalOcean Spaces (for image uploads - configure later)
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=
